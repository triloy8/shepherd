{
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.server.json",
    "check": "bun run build",
    "test": "bun test",
    "start": "bun run start:discord",
    "start:discord": "bun run server/adapters/discord/bot.ts",
    "dev": "bun run dev:discord",
    "dev:discord": "bun run build && bun run start:discord",
    "build:bin": "bun build --compile server/adapters/discord/bot.ts --outfile release/shepherd-discord"
  },
  "dependencies": {
    "discord.js": "^14.22.1"
  },
  "devDependencies": {
    "@types/node": "^22.18.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
